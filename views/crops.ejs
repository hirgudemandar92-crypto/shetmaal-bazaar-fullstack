<%- include('partials/header') %>
<section class="section">
  <div class="container">
    <h2>उपलब्ध पिके</h2>
    <form class="search-bar inline-form" method="GET" action="/crops">
      <input name="q" placeholder="पिक शोधा" value="<%= filters.q %>" />
      <input name="category" placeholder="प्रकार" value="<%= filters.category %>" />
      <input name="location" placeholder="ठिकाण" value="<%= filters.location %>" />
      <button type="submit">शोधा</button>
    </form>

    <div class="grid-3">
      <% if (!crops.length) { %>
        <div class="empty-box">कोणतेही पीक उपलब्ध नाही.</div>
      <% } %>
      <% crops.forEach(crop => { %>
        <div class="card crop-card">
          <% if (crop.image_path) { %>
            <img src="<%= crop.image_path %>" alt="<%= crop.name %>" />
          <% } else { %>
            <div class="hero-card" style="text-align:center;">🌽 फोटो उपलब्ध नाही</div>
          <% } %>
          <div>
            <h3><%= crop.name %></h3>
            <p><%= crop.description || 'गुणवत्तापूर्ण पीक उपलब्ध आहे.' %></p>
            <div class="crop-meta">
              <span>₹<%= crop.price %>/<%= crop.unit %></span>
              <span>स्टॉक: <%= crop.stock %> <%= crop.unit %></span>
              <span><%= crop.category %></span>
              <span><%= crop.location %></span>
            </div>
            <p>शेतकरी: <strong><%= crop.farmer_name %></strong></p>
            <div class="hero-actions">
              <a class="btn" href="/crop/<%= crop.id %>">तपशील</a>
              <% if (currentUser && currentUser.role === 'buyer') { %>
                <form method="POST" action="/cart/add/<%= crop.id %>">
                  <button type="submit" class="btn secondary">कार्टमध्ये जोडा</button>
                </form>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
<%- include('partials/footer') %>
